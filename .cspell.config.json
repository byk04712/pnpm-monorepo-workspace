{
  "import": [
    "@cspell/dict-lorem-ipsum/cspell-ext.json"
  ],
  "caseSensitive": false,
  "dictionaries": [
    "custom-words"
  ],
  "dictionaryDefinitions": [
    {
      "name": "custom-words",
      "path": "./.cspell/custom-words.txt",
      "addWords": true
    }
  ],
  "ignorePaths": [
    "node_modules",
    "**/node_modules",
    "**/dist/**",
    "**/lib/**",
    "**/docs/**",
    "**/language/**",
    "**/language.ts",
    "**/package.json",
    "pnpm-lock.yaml",
    "eslint.config.mjs"
  ]
}
